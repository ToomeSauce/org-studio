# Org Studio — Environment Configuration

# API authentication (optional — if set, all mutation requests require Authorization: Bearer <key>)
# Leave unset for localhost development without auth
# ORG_STUDIO_API_KEY=your-secret-key-here

# Runtime connection (optional — enables live agent status, cron, sessions)
# Default adapter: OpenClaw Gateway (WebSocket)
# GATEWAY_URL=ws://127.0.0.1:18789
# GATEWAY_TOKEN=your-gateway-token-here

# Agent workspace base (optional — parent dir containing workspace-{agentId}/ dirs for ORG.md sync)
# WORKSPACE_BASE=/home/user/.openclaw

# Memory directory (optional — path to agent memory/workspace files for the Memory page)
# MEMORY_DIR=/path/to/workspace

# Doc sources (optional — JSON array of directories to scan for the Docs page)
# DOC_SOURCES='[{"dir":"/path/to/docs","category":"Docs","prefix":"docs"}]'
